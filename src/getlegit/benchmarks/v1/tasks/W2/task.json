{
  "task_id": "W2",
  "category": "write",
  "level": 2,
  "level_multiplier": 1.5,
  "title": "Incident report",
  "description": "Write an incident report documenting a technical outage or system failure, including timeline, root cause analysis, impact assessment, and remediation steps.",
