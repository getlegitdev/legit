    { "type": "required_fields", "weight": 3, "fields": ["title", "summary", "timeline", "root_cause", "impact", "remediation"] },
    { "type": "keyword_present", "weight": 2, "keywords": [] }
  ],
  "variants": ["a", "b", "c"]
}
