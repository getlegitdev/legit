          "type": "object",
          "properties": {
            "timestamp": { "type": "string" },
            "event": { "type": "string" }
          }
        }
      },
      "root_cause": { "type": "string" },
      "impact": { "type": "string" },
      "remediation": { "type": "string" },
      "severity": { "type": "string" },
      "lessons_learned": { "type": "string" }
    }
  },
  "layer1_checks": [
