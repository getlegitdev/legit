{
  "task_id": "C6",
  "category": "code",
  "level": 4,
  "level_multiplier": 3.0,
  "title": "Multi-file debugging",
  "description": "Debug an application spanning multiple Python modules where bugs interact across file boundaries. Identify all bugs and provide corrected code for each file.",
  "time_limit_seconds": 1200,
  "baseline_seconds": 600,
  "allowed_tools": ["code_execute"],
  "layer1_weight": 0.50,
  "layer2_weight": 0.50,
  "output_schema": {
    "type": "object",
    "required": ["fixed_files", "bugs_found", "interaction_analysis", "test_results"],
    "properties": {
      "fixed_files": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["filename", "fixed_code"],
          "properties": {
            "filename": { "type": "string" },
            "fixed_code": { "type": "string" }
          }
        }
      },
      "bugs_found": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["file", "line", "bug_type", "description", "fix"],
          "properties": {
            "file": { "type": "string" },
            "line": { "type": "number" },
            "bug_type": { "type": "string" },
            "description": { "type": "string" },
            "fix": { "type": "string" }
          }
        }
      },
      "interaction_analysis": {
        "type": "string"
      },
      "test_results": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["test_name", "passed", "output"],
          "properties": {
            "test_name": { "type": "string" },
            "passed": { "type": "boolean" },
            "output": { "type": "string" }
          }
        }
      }
    }
  },
  "layer1_checks": [
    { "type": "schema_valid", "weight": 10 },
    { "type": "min_count", "weight": 10, "field": "fixed_files", "min": 2 },
    { "type": "min_count", "weight": 10, "field": "bugs_found", "min": 3 },
    { "type": "keyword_present", "weight": 10, "keywords": ["bug", "fix", "interaction", "cross-file"] },
    { "type": "required_fields", "weight": 10, "fields": ["interaction_analysis"] }
  ],
  "variants": ["a", "b", "c"]
}
